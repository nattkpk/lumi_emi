# Database connection string (e.g., Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[SUBASE_ID]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Port for the API to run on (Render uses process.env.PORT automatically)
PORT=3001

# Secret Key for JSON Web Token (Authentication)
# Generate a strong secret string (e.g., using `openssl rand -hex 64`)
JWT_SECRET="your_super_secret_jwt_signature_key_here"
